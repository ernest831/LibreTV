{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "libretv",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules/**/*",
      ".git/**/*"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
